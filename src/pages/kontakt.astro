---
// src/pages/kontakt.astro
import Base from '../layouts/Base.astro'
---

<Base title="Kontakt" description="Kostenloses Erstgespräch mit TR Creative vereinbaren. Toni Rönnspieß, Aschersleben.">
  <!-- Header -->
  <section class="bg-navy text-white py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold text-sm uppercase tracking-widest mb-3">Erstgespräch vereinbaren</p>
      <h1 class="font-heading text-4xl md:text-5xl mb-4">Kontakt</h1>
      <p class="text-white/70 text-lg">Schreib mir kurz was du machst und was du dir wünschst. Ich melde mich innerhalb von 24 Stunden.</p>
    </div>
  </section>

  <!-- Form + Infos -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-14">
      <!-- Formular -->
      <form
        name="kontakt"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-5"
      >
        <input type="hidden" name="form-name" value="kontakt" />
        <p class="hidden">
          <label>Nicht ausfüllen: <input name="bot-field" /></label>
        </p>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="name">Name</label>
          <input
            id="name" name="name" type="text" required
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-navy"
            placeholder="Max Mustermann"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="unternehmen">Unternehmen</label>
          <input
            id="unternehmen" name="unternehmen" type="text"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-navy"
            placeholder="Muster GmbH"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="email">E-Mail</label>
          <input
            id="email" name="email" type="email" required
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-navy"
            placeholder="max@beispiel.de"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="nachricht">Was beschäftigt dich?</label>
          <textarea
            id="nachricht" name="nachricht" rows="5" required
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-navy resize-none"
            placeholder="Kurz beschreiben was du machst, was fehlt und was du dir vorstellst..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-gold text-navy font-semibold py-3 rounded-lg hover:brightness-110 transition"
        >
          Nachricht senden
        </button>
      </form>

      <!-- Kontakt-Infos -->
      <div class="space-y-8">
        <div>
          <h2 class="font-heading text-xl text-navy mb-4">Direkt erreichen</h2>
          <div class="space-y-3 text-sm text-gray-600">
            <div class="flex items-center gap-3">
              <span class="text-gold text-lg">✉</span>
              <a href="mailto:info@tr-creative.de" class="hover:text-navy">info@tr-creative.de</a>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-gold text-lg">📍</span>
              <span>Aschersleben, Sachsen-Anhalt</span>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6">
          <h3 class="font-heading text-navy text-lg mb-2">Wie läuft das Erstgespräch ab?</h3>
          <ol class="space-y-2 text-sm text-gray-600">
            <li class="flex gap-2"><span class="text-gold font-bold">1.</span> Du schreibst mir — kurz, kein Aufwand.</li>
            <li class="flex gap-2"><span class="text-gold font-bold">2.</span> Ich melde mich innerhalb von 24 h.</li>
            <li class="flex gap-2"><span class="text-gold font-bold">3.</span> Kurzes Gespräch — ich lerne dein Unternehmen kennen.</li>
            <li class="flex gap-2"><span class="text-gold font-bold">4.</span> Du bekommst einen konkreten Vorschlag.</li>
          </ol>
        </div>
      </div>
    </div>
  </section>
</Base>
