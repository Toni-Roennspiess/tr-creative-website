    </div>
  </section>

  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto space-y-8 text-gray-700 text-sm leading-relaxed">

      <div>
        <h2 class="font-heading text-xl text-navy mb-3">Angaben gemäß § 5 TMG</h2>
        <p>Toni Rönnspieß</p>
        <p>TR Creative</p>
        <p>Am Teichberg 2</p>
        <p>06449 Aschersleben</p>
      </div>

      <div>
        <h2 class="font-heading text-xl text-navy mb-3">Kontakt</h2>
        <p>E-Mail: <a href="mailto:toniroennspiess@tr-creative.de" class="text-navy underline hover:text-gold">toniroennspiess@tr-creative.de</a></p>
