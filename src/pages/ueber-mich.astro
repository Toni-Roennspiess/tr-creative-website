---
// src/pages/ueber-mich.astro
import Base from '../layouts/Base.astro'
import PageHero from '../components/PageHero.astro'
import CtaSection from '../components/CtaSection.astro'

const schritte = [
  { nummer: '01', titel: 'Situation verstehen', text: 'Was läuft gut, was fehlt, was ist das Ziel. Ich lerne deinen Betrieb kennen bevor ich irgendetwas produziere.' },
  { nummer: '02', titel: 'Strategie entwickeln', text: 'Welche Inhalte, welche Plattformen, welcher Rhythmus. Eine Strategie die zu deinem Unternehmen und deiner Zielgruppe passt.' },
  { nummer: '03', titel: 'Umsetzen und optimieren', text: 'Content produzieren, veröffentlichen, auswerten und verbessern. Ein kontinuierlicher Prozess der immer besser wird.' },
]
---

<Base
  title="Über mich"
  description="Toni Rönnspieß, Gründer von TR Creative. Social Media Agentur aus Aschersleben, Sachsen-Anhalt."
>
  <PageHero eyebrow="Wer steckt dahinter" headline="Über mich" />

  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-16 items-start fade-in">
        <div class="w-full md:w-72 shrink-0">
          <img
            src="/toni.png"
            alt="Toni Rönnspieß, Gründer TR Creative"
            width="288"
            height="384"
            class="rounded-2xl w-full object-cover aspect-[3/4]"
          />
        </div>
        <div class="flex-1">
          <h2 class="font-heading font-extrabold text-3xl text-cream mb-6">Hallo, ich bin Toni.</h2>
          <p class="text-muted leading-relaxed mb-5">
            Ich bin Gründer von TR Creative und helfe Unternehmen dabei, sich auf Social Media professionell zu positionieren. Mit Content der nicht nur gut aussieht, sondern echte Ergebnisse bringt.
          </p>
          <p class="text-muted leading-relaxed mb-5">
            Was mich von anderen unterscheidet: Ich verstehe wie Unternehmen wirklich funktionieren. Ich weiß was lokale Betriebe bewegt und was mittelständische Unternehmen brauchen. Kein generischer Content, sondern Inhalte die zur Marke, zur Region und zur Zielgruppe passen.
          </p>
          <p class="text-muted leading-relaxed">
            Ich arbeite nicht mit Einheitslösungen. Jeder Kunde bekommt eine eigene Strategie. Und ich bleibe so lange dabei bis die Ergebnisse stimmen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-surface/40">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="font-mono text-accent-soft text-xs uppercase tracking-widest mb-4">So arbeite ich</p>
        <h2 class="font-heading font-extrabold text-3xl text-cream">Meine Arbeitsweise</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {schritte.map((s, i) => (
          <div class="glass-card rounded-2xl p-8 fade-in" style={`transition-delay: ${i * 100}ms`}>
            <div class="font-mono text-accent text-2xl font-bold mb-4">{s.nummer}</div>
            <h3 class="font-heading font-bold text-xl text-cream mb-3">{s.titel}</h3>
            <p class="text-muted text-sm leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaSection
    headline="Lass uns zusammenarbeiten."
    subtext="Kostenloses Erstgespräch. Ich freue mich drauf."
    ctaPrimary="Kontakt aufnehmen"
    ctaPrimaryHref="/kontakt"
    ctaSecondary="WhatsApp schreiben"
    ctaSecondaryHref="https://wa.me/491709870872"
  />
</Base>
