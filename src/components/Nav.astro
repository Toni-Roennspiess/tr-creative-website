---
// src/components/Nav.astro
const links = [
  { href: '/',            label: 'Home' },
  { href: '/leistungen',  label: 'Leistungen' },
  { href: '/ueber-mich',  label: 'Über mich' },
  { href: '/kontakt',     label: 'Kontakt' },
]
const currentPath = Astro.url.pathname
---

<nav class="bg-navy text-white px-6 py-4 flex items-center justify-between">
  <a href="/" class="flex items-center gap-3">
    <img src="/logo-dunkel.svg" alt="TR Creative" class="h-8" />
  </a>

  <!-- Desktop -->
  <ul class="hidden md:flex gap-8 text-sm font-medium">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class={`hover:text-gold transition-colors ${currentPath === link.href ? 'text-gold' : ''}`}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <a
    href="/kontakt"
    class="hidden md:inline-block bg-gold text-navy font-semibold px-5 py-2 rounded hover:brightness-110 transition text-sm"
  >
    Jetzt anfragen
  </a>

  <!-- Mobile Hamburger (einfach: Links untereinander via Details/Summary) -->
  <details class="md:hidden">
    <summary class="cursor-pointer list-none">
      <span class="text-2xl">☰</span>
    </summary>
    <ul class="absolute right-4 top-16 bg-navy border border-gold rounded p-4 flex flex-col gap-3 z-50 text-sm">
      {links.map(link => (
        <li><a href={link.href} class="hover:text-gold">{link.label}</a></li>
      ))}
      <li>
        <a href="/kontakt" class="bg-gold text-navy font-semibold px-4 py-2 rounded block text-center">
          Jetzt anfragen
        </a>
      </li>
    </ul>
  </details>
</nav>
