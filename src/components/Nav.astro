---
// src/components/Nav.astro
const links = [
  { href: '/', label: 'Home' },
  { href: '/leistungen', label: 'Leistungen' },
  { href: '/ueber-mich', label: 'Über mich' },
  { href: '/referenzen', label: 'Referenzen' },
  { href: '/kontakt', label: 'Kontakt' },
]
const currentPath = Astro.url.pathname
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="nav">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <a href="/" class="flex items-center shrink-0">
      <img src="/logo-dunkel.svg" alt="TR Creative" class="h-8" />
    </a>

    <ul class="hidden md:flex gap-8 text-sm font-medium">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={`transition-colors duration-200 hover:text-accent-soft ${
              currentPath === link.href ? 'text-accent-soft' : 'text-cream/70'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="https://wa.me/491709870872"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:flex items-center gap-2 bg-[#25D366] text-white text-sm font-semibold px-4 py-2 rounded-lg hover:brightness-110 transition-all duration-200"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.527 5.845L.057 23.215a.75.75 0 00.928.928l5.37-1.47A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.99 0-3.86-.549-5.455-1.505l-.39-.232-4.044 1.106 1.106-4.044-.232-.39A9.953 9.953 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
      </svg>
      WhatsApp
    </a>

    <button
      class="md:hidden text-cream p-3"
      id="menu-toggle"
      aria-label="Menü öffnen"
      aria-expanded="false"
    >
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <div class="hidden md:hidden" id="mobile-menu" aria-hidden="true">
    <ul class="flex flex-col gap-4 px-6 py-6 bg-surface border-t border-accent/10">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={`transition-colors text-base block py-1 hover:text-accent-soft ${currentPath === link.href ? 'text-accent-soft' : 'text-cream/80'}`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="https://wa.me/491709870872"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#25D366] text-white text-sm font-semibold px-4 py-3 rounded-lg"
        >
          WhatsApp schreiben
        </a>
      </li>
    </ul>
  </div>
</header>

<div class="h-16"></div>

<script>
  const nav = document.getElementById('nav')
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('bg-midnight/90', 'backdrop-blur-md', 'border-b', 'border-accent/10', 'shadow-lg')
    } else {
      nav?.classList.remove('bg-midnight/90', 'backdrop-blur-md', 'border-b', 'border-accent/10', 'shadow-lg')
    }
  })

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden')
    menu?.classList.toggle('hidden', !isHidden)
    menu?.setAttribute('aria-hidden', String(!isHidden))
    toggle.setAttribute('aria-expanded', String(isHidden))
  })
</script>
