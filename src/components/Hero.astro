---
// src/components/Hero.astro
---

<section class="bg-navy text-white py-24 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-4">Social Media Marketing</p>
    <h1 class="font-heading text-4xl md:text-6xl leading-tight mb-6">
      Mehr Kunden.<br />Mehr Reichweite.<br />Mehr Umsatz.
    </h1>
    <p class="text-white/70 text-lg mb-10 max-w-xl mx-auto">
      Ich helfe lokalen Unternehmen in Sachsen-Anhalt, sich online zu positionieren —
      mit Content der wirkt und Werbung die verkauft.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/kontakt"
        class="bg-gold text-navy font-semibold px-8 py-3 rounded hover:brightness-110 transition text-base"
      >
        Kostenloses Erstgespräch
      </a>
      <a
        href="/leistungen"
        class="border border-white/40 text-white px-8 py-3 rounded hover:border-gold hover:text-gold transition text-base"
      >
        Leistungen ansehen
      </a>
    </div>
  </div>
</section>
